<?xml version = "1.0"?>
<robot xmlns:xacro = "http://www.ros.org/wiki/xacro">

    <xacro:include filename = "inertia_macros.xacro"/>

    <!-- Materials -->

    <material name = "white">
        <color rgba = "1 1 1 1"/>
    </material>

    <material name = "black">
        <color rgba = "0 0 0 1"/>
    </material>

    <material name = "orange">
        <color rgba = "1 0.65 0 1"/>
    </material>

    <material name = "blue">
        <color rgba = "0 0 1 1"/>
    </material>

    <material name = "red">
        <color rgba = "1 0 0 1"/>
    </material>

    <!-- Base Link -->

    <link name = "base_link">

    </link>

    <!-- Base Footprint Link -->

    <link name="base_footprint">

    </link> 

    <!-- Base Footprint Joint -->

    <joint name="base_foorprint_joint" type="fixed">
        <parent link="base_link"/>
        <child link="base_footprint"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Chassis Link -->

    <link name = "chassis">
        <visual>
            <origin xyz = "0.11 0 0.0415"/>
            <geometry>
                <box size = "0.245 0.15 0.123"/>
            </geometry>
            <material name = "black"/>
        </visual>
        <collision>
            <origin xyz = "0.11 0 0.0415"/>
            <geometry>
                <box size = "0.245 0.15 0.123"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass = "0.5" x = "0.245" y = "0.15" z = "0.123">
            <origin xyz = "0.11 0 0.0415" rpy = "0 0 0"/>
        </xacro:inertial_box>
    </link>

    <gazebo reference = "chassis">
        <material> 
            Gazebo/Black 
        </material>
    </gazebo>

    <!-- Chassis/Base Joint -->

    <joint name = "chassis_joint" type = "fixed">
        <parent link = "base_link"/>
        <child link = "chassis"/>
        <origin xyz = "-0.210 0 0"/>
    </joint>
    
    <!-- Left Wheel Link -->

    <link name = "left_wheel">
        <visual>
            <origin xyz = "0 0 0"/>
            <geometry>
                <cylinder radius = "0.03375" length = "0.026"/>
            </geometry>
            <material name = "orange"/>
        </visual>
        <collision>
            <origin xyz = "0 0 0"/>
            <geometry>
                <sphere radius = "0.03375"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass = "0.1" length = "0.026" radius = "0.03375">
            <origin xyz = "0 0 0" rpy = "0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference = "left_wheel">
        <material> 
            Gazebo/Orange 
        </material>
    </gazebo>

    <!-- Left Wheel Joint -->

    <joint name = "left_wheel_joint" type = "continuous">
        <parent link = "base_link"/>
        <child link = "left_wheel"/>
        <origin xyz = "0 0.096 0" rpy = "-${pi/2} 0 0"/>
        <axis xyz = " 0 0 1"/>
    </joint>

    <!-- Right Wheel Link -->

    <link name = "right_wheel">
        <visual>
            <origin xyz = "0 0 0"/>
            <geometry>
                <cylinder radius = "0.03375" length = "0.026"/>
            </geometry>
            <material name = "orange"/>
        </visual>
        <collision>
            <origin xyz = "0 0 0"/>
            <geometry>
                <sphere radius = "0.03375"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass = "0.1" length = "0.026" radius = "0.03375">
            <origin xyz = "0 0 0" rpy = "0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference = "right_wheel">
        <material> 
            Gazebo/Orange 
        </material>
    </gazebo>

    <!-- Right Wheel Joint -->

    <joint name = "right_wheel_joint" type = "continuous">
        <parent link = "base_link"/>
        <child link = "right_wheel"/>
        <origin xyz = "0 -0.096 0" rpy = "${pi/2} 0 0"/>
        <axis xyz = " 0 0 -1"/>
    </joint>

    <!-- Caster Back Wheel Link -->

    <link name = "caster_back">
        <visual>
            <origin xyz = "0 0 0"/>
            <geometry>
                <sphere radius = "0.025"/>
            </geometry>
            <material name = "white"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius = "0.025"/>
            </geometry>
        </collision>
        <xacro:inertial_sphere mass = "0.1" radius = "0.025">
            <origin xyz = "0 0 0" rpy = "0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference = "caster_back">
        <material> 
            Gazebo/White 
        </material>
        <mu1 value = "0.001"/>
        <mu2 value = "0.001"/>
    </gazebo>

    <!-- Caster Back Wheel Joint -->

    <joint name = "caster_back_wheel" type = "fixed">
        <parent link = "chassis"/>
        <child link = "caster_back"/>
        <origin xyz = "0.025 0 -0.009"/>
    </joint>

</robot>