<?xml version = "1.0"?>
<robot xmlns:xacro = "http://www.ros.org/wiki/xacro">

    <xacro:include filename = "inertia_macros.xacro"/>

    <!-- Materials -->

    <material name = "white">
        <color rgba = "1 1 1 1"/>
    </material>

    <material name = "black">
        <color rgba = "0 0 0 1"/>
    </material>

    <material name = "orange">
        <color rgba = "1 0.65 0 1"/>
    </material>

    <material name = "blue">
        <color rgba = "0 0 1 1"/>
    </material>

    <material name = "red">
        <color rgba = "1 0 0 1"/>
    </material>

    <!-- Base Link -->

    <link name = "base_link">

    </link>

    <!-- Base Footprint Link -->

    <link name="base_footprint">

    </link> 

    <!-- Base Footprint Joint -->

    <joint name="base_foorprint_joint" type="fixed">
        <parent link="base_link"/>
        <child link="base_footprint"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Chassis Link -->

    <link name = "chassis">
        <visual>
            <origin xyz = "0.125 0 0.0415"/>
            <geometry>
                <box size = "0.250 0.155 0.123"/>
            </geometry>
            <material name = "black"/>
        </visual>
        <collision>
            <origin xyz = "0.125 0 0.0415"/>
            <geometry>
                <box size = "0.250 0.155 0.123"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass = "0.5" x = "0.250" y = "0.155" z = "0.123">
            <origin xyz = "0.125 0 0.0415" rpy = "0 0 0"/>
        </xacro:inertial_box>
    </link>

    <gazebo reference = "chassis">
        <material> 
            Gazebo/Black 
        </material>
    </gazebo>

    <!-- Chassis/Base Joint -->

    <joint name = "chassis_joint" type = "fixed">
        <parent link = "base_link"/>
        <child link = "chassis"/>
        <origin xyz = "-0.125 0 0"/>
    </joint>
    
    <!-- Stepper Link -->

    <link name="stepper_link">
        <visual>
            <origin xyz="0 0 0.0415"/>
            <geometry>
                <box size="0.048 0.048 0.043"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.0415"/>
            <geometry>
                <box size="0.048 0.048 0.043"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass = "0.5" x = "0.048" y = "0.048" z = "0.043">
            <origin xyz = "0 0 0.0415" rpy = "0 0 0"/>
        </xacro:inertial_box>
    </link>

    <gazebo reference="stepper_link">
        <material> 
            Gazebo/Black 
        </material>
    </gazebo>

    <!-- Stepper Joint -->

    <joint name="stepper_joint" type="fixed">
        <parent link="base_link"/>
        <child link="stepper_link"/>
        <origin xyz="0 0 0.123"/>
    </joint>

    <!-- Shaft Link -->

    <link name="shaft_link">
        <visual>
            <origin xyz="0 0 0.018"/>
            <geometry>
                <cylinder radius="0.01" length="0.036"/>
            </geometry>
            <material name="orange"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.018"/>
            <geometry>
                <cylinder radius="0.01" length="0.036"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass = "0.1" length = "0.036" radius = "0.01">
            <origin xyz = "0 0 0.018" rpy = "0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="shaft_link">
        <material> 
            Gazebo/Orange 
        </material>
    </gazebo>

    <!-- Shaft Joint -->

    <joint name="shaft_joint" type="fixed">
        <parent link="stepper_link"/>
        <child link="shaft_link"/>
        <origin xyz="0 0 0.043" rpy="0 0 0"/>
    </joint>

    <!-- Bracket Link -->

    <link name="bracket_link">
        <visual>
            <origin xyz="-0.012 0 0.005"/>
            <geometry>
                <box size="0.045 0.03 0.01"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="-0.012 0 0.005"/>
            <geometry>
                <box size="0.045 0.03 0.01"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass = "0.1" x = "0.045" y = "0.03" z = "0.01">
            <origin xyz = "0 -0.012 0.005" rpy = "0 0 0"/>
        </xacro:inertial_box>
        <visual>
            <origin xyz="-0.0255 0 0.050" rpy="0 ${pi/2} 0"/>
            <geometry>
                <cylinder radius="0.0415" length="0.018"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="-0.0255 0 0.050" rpy="0 ${pi/2} 0"/>
            <geometry>
                <cylinder radius="0.0415" length="0.018"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass = "0.1" length = "0.018" radius = "0.0415">
            <origin xyz = "-0.0255 0 0.050" rpy="0 ${pi/2} 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="bracket_link">
        <material> 
            Gazebo/White 
        </material>
    </gazebo>

    <!-- Bracket Joint -->

    <joint name="bracket_joint" type="fixed">
        <parent link="shaft_link"/>
        <child link="bracket_link"/>
        <origin xyz="0 0 0.036" rpy="0 0 0"/>
    </joint>

    <!-- Left Wheel Link -->

    <link name = "left_wheel">
        <visual>
            <origin xyz = "0 0 0"/>
            <geometry>
                <cylinder radius = "0.09704" length = "0.041"/>
            </geometry>
            <material name = "orange"/>
        </visual>
        <collision>
            <origin xyz = "0 0 0"/>
            <geometry>
                <sphere radius = "0.09704"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass = "0.1" length = "0.041" radius = "0.09704">
            <origin xyz = "0 0 0" rpy = "0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference = "left_wheel">
        <material> 
            Gazebo/Orange 
        </material>
    </gazebo>

    <!-- Left Wheel Joint -->

    <joint name = "left_wheel_joint" type = "continuous">
        <parent link = "base_link"/>
        <child link = "left_wheel"/>
        <origin xyz = "0 0.110 0" rpy = "-${pi/2} 0 0"/>
        <axis xyz = " 0 0 1"/>
    </joint>

    <!-- Right Wheel Link -->

    <link name = "right_wheel">
        <visual>
            <origin xyz = "0 0 0"/>
            <geometry>
                <cylinder radius = "0.09704" length = "0.041"/>
            </geometry>
            <material name = "orange"/>
        </visual>
        <collision>
            <origin xyz = "0 0 0"/>
            <geometry>
                <sphere radius = "0.09704"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass = "0.1" length = "0.041" radius = "0.09704">
            <origin xyz = "0 0 0" rpy = "0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference = "right_wheel">
        <material> 
            Gazebo/Orange 
        </material>
    </gazebo>

    <!-- Right Wheel Joint -->

    <joint name = "right_wheel_joint" type = "continuous">
        <parent link = "base_link"/>
        <child link = "right_wheel"/>
        <origin xyz = "0 -0.110 0" rpy = "${pi/2} 0 0"/>
        <axis xyz = " 0 0 -1"/>
    </joint>

    <!-- Caster Back Wheel Link -->

    <link name = "caster_back">
        <visual>
            <origin xyz = "0 0 0"/>
            <geometry>
                <sphere radius = "0.025"/>
            </geometry>
            <material name = "white"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius = "0.025"/>
            </geometry>
        </collision>
        <xacro:inertial_sphere mass = "0.1" radius = "0.025">
            <origin xyz = "0 0 0" rpy = "0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference = "caster_back">
        <material> 
            Gazebo/White 
        </material>
        <mu1 value = "0.001"/>
        <mu2 value = "0.001"/>
    </gazebo>

    <!-- Caster Back Wheel Joint -->

    <joint name = "caster_back_wheel" type = "fixed">
        <parent link = "chassis"/>
        <child link = "caster_back"/>
        <origin xyz = "0.025 0 -0.07204"/>
    </joint>

    <!-- Caster Front Wheel Link -->

    <link name = "caster_front">
        <visual>
            <origin xyz = "0 0 0"/>
            <geometry>
                <sphere radius = "0.025"/>
            </geometry>
            <material name = "white"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius = "0.025"/>
            </geometry>
        </collision>
        <xacro:inertial_sphere mass = "0.1" radius = "0.025">
            <origin xyz = "0 0 0" rpy = "0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference = "caster_front">
        <material> 
            Gazebo/White 
        </material>
        <mu1 value = "0.001"/>
        <mu2 value = "0.001"/>
    </gazebo>

    <!-- Caster Front Wheel Joint -->

    <joint name = "caster_front_wheel" type = "fixed">
        <parent link = "chassis"/>
        <child link = "caster_front"/>
        <origin xyz = "0.225 0 -0.07204"/>
    </joint>

</robot>